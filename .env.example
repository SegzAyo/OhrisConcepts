# Use Supabase's transaction pooler (port 6543) for Vercel Functions.
# Keep the real value in .env.local and Vercel Project Settings, never in Git.
DATABASE_URL=postgresql://postgres.mlzejabcgpdftlhsqdqd:YOUR_URL_ENCODED_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Optional: paste the Supabase CA certificate to enable verify-full TLS.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\\n...\\n-----END CERTIFICATE-----"

# Access token for the /admin page (guards /api/submissions). Use a long random
# value, at least 16 characters, e.g. `openssl rand -base64 32`. Without it the
# admin view stays closed. Set it in .env.local and Vercel Project Settings.
ADMIN_TOKEN=YOUR_LONG_RANDOM_ADMIN_TOKEN
